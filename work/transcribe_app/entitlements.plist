<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  NOT USED by the current distribution. The app ships ad-hoc signed WITHOUT the
  hardened runtime (free, non-notarized), where mic capture works via the
  NSMicrophoneUsageDescription string alone and ad-hoc dylibs load without
  library-validation enforcement — so no entitlements are required.

  This set is kept only for a hypothetical FUTURE notarized build (which would
  require an Apple Developer ID + the hardened runtime). If that ever happens:
  - device.audio-input: microphone capture under hardened runtime.
  - cs.allow-unsigned-executable-memory / cs.disable-library-validation: the
    bundled CPython + C extensions (PyAV/ffmpeg, numpy) need these under hardened
    runtime. Apply with:
      codesign --force --options runtime --entitlements entitlements.plist ...
-->
<plist version="1.0">
<dict>
  <key>com.apple.security.device.audio-input</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
